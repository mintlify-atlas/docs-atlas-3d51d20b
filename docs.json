{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Ode",
  "theme": "almond",
  "colors": {
    "primary": "#FF6B6B",
    "light": "#FFE66D",
    "dark": "#4ECDC4"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/rinogodson/ode"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rinogodson/ode"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/card-creation",
              "features/customization",
              "features/slips",
              "features/playback"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/keyboard-shortcuts",
              "guides/importing-exporting",
              "guides/styling-cards"
            ]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Overview",
            "pages": ["components/overview"]
          },
          {
            "group": "Core Components",
            "pages": [
              "components/card-crafter",
              "components/card-preview",
              "components/player",
              "components/slip-popup"
            ]
          },
          {
            "group": "UI Components",
            "pages": [
              "components/color-change-option",
              "components/file-drop-plate",
              "components/slider"
            ]
          }
        ]
      }
    ]
  }
}
