  "keyFeatures": [
    "Create visual playlist cards from YouTube links",
    "Customize card appearance with colors, backgrounds, and emojis",
    "Organize songs into collections using 'Slips'",
    "Drag-and-drop song reordering",
    "Export and import playlist cards",
    "Integrated YouTube player with keyboard controls",
    "Animated visual player interface",
    "Fuzzy search for finding slips"
  ],
  "publicApiSurface": [
    "CardCrafter - Create and edit music cards",
    "CardPreview - Display card visualizations",
    "Player - YouTube playback controls",
    "SlipPopUp - Manage song collections",
    "ColorChangeOption - Card styling interface",
    "FileDropPlate - Import card files",
    "ContextProvider - Global state management",
    "playFn() - Start playback",
    "pauseFn() - Pause playback",
    "seekFn(seconds) - Seek to timestamp",
    "fetchYouTubeTitle(link) - Get video title",
    "download(filename, text) - Export card file"
  ]
